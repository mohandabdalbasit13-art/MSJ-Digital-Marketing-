    <title>MSJ Digital Marketing | خبير تسويق وبيع المنتجات</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-gold: #C5A059; 
            --brand-dark: #1a1a1a;
            --brand-white: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Cairo', sans-serif; }

        body { background-color: #f4f4f4; color: var(--brand-dark); line-height: 1.6; }

        /* Navigation */
        nav {
            background: var(--brand-dark);
            color: white;
            padding: 1rem 5%;
            text-align: center;
            border-bottom: 4px solid var(--brand-gold);
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&q=80');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 6rem 5%;
            text-align: center;
        }

        .hero h1 { font-size: 2.8rem; color: var(--brand-gold); margin-bottom: 1.5rem; }
        .hero p { font-size: 1.3rem; max-width: 800px; margin: 0 auto 2rem; }

        /* Services Grid */
        .container { padding: 4rem 5%; }
        .grid { display: grid; grirepeat-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }

        .card {
            background: white;
            padding: 2.5rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: 0.3s;
        }

        .card:hover { transform: translateY(-10px); }

        .card h3 { color: var(--brand-gold); margin-bottom: 1rem; font-size: 1.5rem; }

        /* Content Section */
        .highlight {
            background: var(--brand-dark);
            color: white;
            padding: 4rem 5%;
            text-align: center;
            margin-top: 2rem;
        }

        .highlight h2 { color: var(--brand-gold); margin-bottom: 1rem; }

        /* WhatsApp Button */
        .cta-btn {
            display: inline-block;
            background: var(--brand-gold);
            color: var(--brand-dark);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.2rem;
            margin-top: 1rem;
            transition: 0.3s;
        }

        .cta-btn:hover { background: white; transform: scale(1.05); }

        .whatsapp-fixed {
            position: fixed;
            bottom: 25px;
            left: 25px;
            background: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 1000;
        }

        footer { text-align: center; padding: 2rem; background: #eee; font-size: 0.9rem; }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
        }
    </style>
</head>
